{
  "name": "telegram-tests-passing-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch src/api/server.ts",
    "dev:bot": "tsx --env-file=.env --watch src/bot/server.ts",
    "dev:webapp": "npm --prefix web run dev",
    "start": "node dist/api/server.js",
    "start:bot": "node --env-file=.env dist/bot/server.js",
    "build:webapp": "npm --prefix web run build",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "docker:up": "docker compose up --build -d"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.6.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
